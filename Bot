class LoreSelect(discord.ui.Select):
    def __init__(self, placeholder: str, options: list):
        super().__init__(
            placeholder=placeholder,
            min_values=1,
            max_values=1,
            options=options,
        )

    async def callback(self, interaction: discord.Interaction):
        key = self.values[0]
        title, text = LORE_DATA.get(key, ("Не найдено", "Раздел не найден."))

        pages = chunk_text(text)

        # Первая страница — всегда с заголовком
        embed = discord.Embed(
            title=title,
            description=pages[0],
            color=ORANGE,
        )
        embed.set_footer(text="Цитадель ⋅ Лор")

        await interaction.response.send_message(
            embed=embed, ephemeral=True
        )

        # Если текст не влез — отправляем followup-страницы
        for i, page in enumerate(pages[1:], start=2):
            extra_embed = discord.Embed(
                title=f"{title} (продолжение {i})",
                description=page,
            color=ORANGE,
            )
            extra_embed.set_footer(text="Цитадель ⋅ Лор")
            await interaction.followup.send(
                embed=extra_embed, ephemeral=True
            )


