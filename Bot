class AutoroleSelect(discord.ui.Select):
    def __init__(self):
        options = []
        for i, (name, role_id) in enumerate(AUTOROLES.items()):
            emoji = SELECT_EMOJIS[i] if i < len(SELECT_EMOJIS) else "🔘"
            clean_name = name.replace("🔴 ", "").replace("🟠 ", "").replace("🟡 ", "").replace("🟢 ", "") \
                            .replace("🔵 ", "").replace("🟣 ", "").replace("⚫ ", "").replace("⚪ ", "") \
                            .replace("🟫 ", "").replace("🩷 ", "").replace("🩶 ", "").replace("🩵 ", "")
            
            options.append(
                discord.SelectOption(
                    label=clean_name,
                    emoji=emoji,
                    value=str(role_id),
                    description=f"Получить роль {clean_name}"
                )
            )
        
        super().__init__(
            placeholder="Выберите роль...",
            min_values=1,
            max_values=1,
            options=options,
            custom_id="autorole_select"
        )

    async def callback(self, interaction: discord.Interaction):
        role_id = int(self.values[0])
        role = interaction.guild.get_role(role_id)
        
        if not role:
            await interaction.response.send_message(
                "<:close:1466473023283662960> Роль не найдена. Обратитесь к администратору.",
                ephemeral=True
            )
            return

        if role in interaction.user.roles:
            await interaction.response.send_message(
                f"<:close:1466473023283662960> У вас уже есть роль {role.mention}!",
                ephemeral=True
            )
            return
        
        await interaction.user.add_roles(role)
        
        await interaction.response.send_message(
            f"<:verify:1466472424986906746> Вам выдана роль {role.mention}!",
            ephemeral=True
        )


class ResetRolesButton(discord.ui.Button):
    def __init__(self):
        super().__init__(
            label="Сбросить",
            style=discord.ButtonStyle.secondary,
            custom_id="reset_roles",
            emoji="<:update:1473043833133469747>"
        )

    async def callback(self, interaction: discord.Interaction):
        autorole_ids = set(AUTOROLES.values())
        current_roles = [r for r in interaction.user.roles if r.id in autorole_ids]
        
        if not current_roles:
            await interaction.response.send_message(
                "<:close:1466473023283662960> У вас нет активных ролей.",
                ephemeral=True
            )
            return
        
        await interaction.user.remove_roles(*current_roles)
        
        roles_mentions = ", ".join([r.mention for r in current_roles])
        await interaction.response.send_message(
            f"<:update:1473043833133469747> Сняты все роли: {roles_mentions}",
            ephemeral=True
        )


