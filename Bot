# Кэш погоды (обновляется раз в день)
_weather_cache = {"date": None, "data": None}


# ─── ФУНКЦИЯ ПОЛУЧЕНИЯ ПОГОДЫ ──────────────────────────────
async def get_weather_data():
    """Получает данные о погоде с кэшированием на 1 день."""
    global _weather_cache

    today = datetime.utcnow().strftime("%Y-%m-%d")

    # Если кэш актуален — возвращаем его
    if _weather_cache["date"] == today and _weather_cache["data"]:
        return _weather_cache["data"]

    # Запрос к OpenWeatherMap
    url = (
        f"https://api.openweathermap.org/data/2.5/weather"
        f"?q={CITY}&appid={WEATHER_API_KEY}&units=metric&lang=ru"
    )

    async with aiohttp.ClientSession() as session:
        async with session.get(url) as resp:
            if resp.status != 200:
                return None
            data = await resp.json()

    # Парсим нужные данные
    main_weather = data["weather"][0]["main"]          # Напр. "Clouds"
    description   = data["weather"][0]["description"]     # Напр. "небольшая облачность"
    temp          = round(data["main"]["temp"])           # Напр. -3

    result = {
        "main":        main_weather,
        "description": description,
        "temp":        temp,
        "icon":        WEATHER_ICONS.get(main_weather, "🌤️"),
        "name_ru":     WEATHER_TRANSLATIONS.get(main_weather, description),
    }

    # Обновляем кэш
    _weather_cache = {"date": today, "data": result}

    return result


# ─── КОМАНДА !WEATHER ──────────────────────────────────────
@commands.command(name="weather")
async def weather_cmd(ctx):
    """Показывает текущую погоду Цитадели."""

    # Отправляем реакцию, пока загружаем данные
    async with ctx.typing:

        weather = await get_weather_data()

        if not weather:
            await ctx.send("⚠️ Не удалось получить данные о погоде.")
            return

        # Формируем знак температуры
        temp_str = f"+{weather['temp']}" if weather["temp"] > 0 else str(weather["temp"])

        # Создаём Embed
        embed = discord.Embed(
            title=f"Погода Цитадели <:{WEATHER_ICON_ID}>",
            description=f"{weather['icon']} {weather['name_ru']} {temp_str}°C",
            color=discord.Color.purple()
        )

        # Footer
        embed.set_footer(text="Цитадель ⋅ Погода")

    await ctx.send(embed=embed)


