# ВСПОМОГАТЕЛЬНАЯ ФУНКЦИЯ — разбивает длинный текст на страницы
# Discord embed description: макс. 4096 символов
# ═══════════════════════════════════════════════════════════════

def chunk_text(text: str, limit: int = 4096) -> list[str]:
    """Разбивает текст на части, не превышающие лимит символов.
    Старается делать разрыв по абзацу, а не посередине слова."""
    if len(text) <= limit:
        return [text]
    chunks = []
    while text:
        if len(text) <= limit:
            chunks.append(text)
            break
        split_at = text.rfind("\n\n", 0, limit)
        if split_at == -1:
            split_at = text.rfind("\n", 0, limit)
        if split_at == -1:
            split_at = limit
        chunks.append(text[:split_at].strip())
        text = text[split_at:].strip()
    return chunks


